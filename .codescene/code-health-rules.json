{
    "rule_sets": [
        {
            "matching_content_path": "**/src/test/**/*.kt",
            "matching_content_path_doc": "All test files - relaxed rules for test code",
            "rules": [
                {
                    "name": "Code Duplication",
                    "weight": 0.0
                },
                {
                    "name": "Duplicated Assertion Blocks",
                    "weight": 0.0
                },
                {
                    "name": "Excess Number of Function Arguments",
                    "weight": 0.0
                },
                {
                    "name": "Primitive Obsession",
                    "weight": 0.0
                },
                {
                    "name": "String Heavy Function Arguments",
                    "weight": 0.0
                }
            ],
            "thresholds": [
                {
                    "name": "function_lines_of_code_warning",
                    "value": 200
                },
                {
                    "name": "function_lines_of_code_alert",
                    "value": 300
                }
            ]
        },
        {
            "matching_content_path": "**/*",
            "matching_content_path_doc": "Default fallback for all other files",
            "rules": [ ],
            "thresholds": [ ]
        }
    ]
}